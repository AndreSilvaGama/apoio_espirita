{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tanstack-start-app",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "routes": [
    { "pattern": "apoioespirita.com.br/*", "zone_name": "apoioespirita.com.br" },
    { "pattern": "www.apoioespirita.com.br/*", "zone_name": "apoioespirita.com.br" }
  ]
}
